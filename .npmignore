# ShipKit — npm ignores (published files controlled by package.json "files")
# The "files" field in package.json whitelists: bin/, template/
# Everything else is excluded from the npm package

# Dev files
.gitignore
.npmignore
.gitattributes
*.md
!README.md

# CI/CD (not needed at runtime)
.github/

# Docs site (not needed at runtime)
docs/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
