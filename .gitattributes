# Auto detect text files and use LF
* text=auto

# Shell scripts should use LF
*.sh text eol=lf
*.ps1 text eol=crlf

# Markdown and text files
*.md text
*.yml text eol=lf
*.yaml text eol=lf
*.json text
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.svg text
